# EAS .easignore — strips everything EAS Build doesn't need from the upload.

# --- Flutter (legacy, not needed for RN build) ---
/android
/ios
/lib
/macos
/windows
/linux
/test
/build
/.dart_tool
/.flutter-plugins
/.flutter-plugins-dependencies

# --- Native folders 전체 — EAS 가 매 빌드 fresh prebuild 하도록 강제. ---
# 핵심 fix: 이전엔 ios/Pods, ios/build 만 제외하고 ios/ 통째로 업로드 →
# EAS 가 stale Info.plist (GADApplicationIdentifier 누락) 사용해서 prebuild 스킵.
# AdMob SDK 가 init 시 GADApplicationIdentifier 검증 못해 SIGABRT (TestFlight #55, #56).
# .gitignore 는 .easignore 에 영향 없음 — EAS 는 untracked 도 업로드.
apps/mobile-rn/ios
apps/mobile-rn/android

# --- Design & docs ---
*.pen
*.png
!assets/*.png
!assets/**/*.png
/screenshots
/export
*.tar.gz

# --- Dev tools ---
.claude
.git
.vscode
*.md
!README.md

# --- Large artifacts ---
/fortune-transfer-bundle-*
/pencil*

# --- Past RN build outputs ---
apps/mobile-rn/build-*.ipa
apps/mobile-rn/dist

# --- Supabase local state ---
supabase/.temp
supabase/.branches

# --- Node / Expo caches (EAS reinstalls) ---
**/node_modules
.expo
.expo-shared
.metro-cache

# --- Env & secrets (EAS pulls from its own secrets) ---
.env
.env.*
!.env.example
*.pem
*.p8
*.p12
*.mobileprovision
