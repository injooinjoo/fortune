{
  "name": "@fortune/mobile-rn",
  "version": "1.0.14",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go --tunnel",
    "start:native": "react-native start --projectRoot . --port 8081",
    "start:remote-native": "node scripts/remote-metro.mjs",
    "native:doctor": "node scripts/local-ios.mjs doctor",
    "native:prepare": "node scripts/local-ios.mjs prepare",
    "native:pods": "node scripts/local-ios.mjs pods",
    "native:build": "node scripts/local-ios.mjs build",
    "native:device:build": "node scripts/local-ios.mjs device-build",
    "native:device:install": "node scripts/local-ios.mjs device-install",
    "native:device:launch": "node scripts/local-ios.mjs device-launch",
    "native:device:run": "node scripts/local-ios.mjs device-run",
    "ios:xcode": "node scripts/local-ios.mjs open",
    "ios:local": "node scripts/local-ios.mjs run",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "deploy:ota": "tsc --noEmit && eas update --branch production --message \"$(git log -1 --format=%s)\" --non-interactive",
    "deploy:native": "eas build --profile production --platform ios --auto-submit --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@fortune/design-tokens": "file:../../packages/design-tokens",
    "@fortune/product-contracts": "file:../../packages/product-contracts",
    "@fortune/saju-engine": "file:../../packages/saju-engine",
    "@react-navigation/native": "7.2.2",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.86.2",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^3.4.13",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.7",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~31.0.10",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.10",
    "llama.rn": "^0.12.0-rc.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-shared-group-preferences": "^1.1.24",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo/ngrok": "^4.1.3",
    "@react-native-community/cli": "20.1.3",
    "@react-native/metro-config": "0.81.5",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-shared-group-preferences"
        ]
      }
    }
  },
  "private": true
}
