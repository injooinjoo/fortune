{
  "permissions": {
    "allow": [
      "Bash(supabase functions*)",
      "Bash(supabase db*)",
      "Bash(supabase migration*)",
      "Bash(supabase start*)",
      "Bash(supabase stop*)",
      "Bash(supabase status*)",
      "Bash(eas update*)",
      "Bash(eas build*)",
      "Bash(eas channel*)",
      "Bash(eas whoami*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run deploy:ota*)",
      "Bash(npm run source-inventory*)",
      "Bash(npm run figma*)",
      "Bash(npx tsc*)",
      "Bash(npx expo*)",
      "Bash(npx playwright*)",
      "Bash(./scripts/auto-deploy-on-stop.sh*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git ls-files*)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(open *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/auto-deploy-on-stop.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
