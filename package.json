{
  "name": "fortune-monorepo",
  "version": "1.0.0",
  "description": "Ondo (온도) — AI fortune & companion chat app monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "pencil:version": "npx -y @pencil.dev/cli version",
    "pencil:login": "npx -y @pencil.dev/cli login",
    "pencil:status": "npx -y @pencil.dev/cli status",
    "pencil:interactive": "npx -y @pencil.dev/cli interactive",
    "lint": "echo \"No frontend lint configured in CI. Skipping.\"",
    "typecheck": "npm run rn:typecheck",
    "build": "npm run rn:web:export",
    "test": "playwright test",
    "test:smoke": "playwright test playwright/tests/smoke.spec.js --project=chromium",
    "test:smoke:ci": "CI=true playwright test playwright/tests/smoke.spec.js --project=chromium",
    "test:e2e": "playwright test playwright/tests/e2e/",
    "test:e2e:ci": "CI=true playwright test playwright/tests/e2e/ --project=chromium",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:codegen": "playwright codegen",
    "rn:typecheck": "npm run typecheck --workspace @fortune/product-contracts --workspace @fortune/design-tokens --workspace @fortune/mobile-rn",
    "rn:test": "npm run test --workspace @fortune/product-contracts",
    "rn:web:export": "corepack pnpm --filter @fortune/mobile-rn exec expo export --platform web --output-dir ../../dist/mobile-rn-web",
    "serve:rn-web": "npx serve dist/mobile-rn-web -l 3000 --single",
    "sync:edge-pricing": "bash scripts/sync-edge-pricing.sh",
    "check:edge-pricing": "bash scripts/sync-edge-pricing.sh && git diff --exit-code -- supabase/functions/_shared/fortune-pricing-generated.ts",
    "lighthouse": "lhci autorun",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "rn:start:native": "pnpm --filter @fortune/mobile-rn start:native",
    "rn:start:remote-native": "pnpm --filter @fortune/mobile-rn start:remote-native",
    "rn:native:doctor": "pnpm --filter @fortune/mobile-rn native:doctor",
    "rn:native:prepare": "pnpm --filter @fortune/mobile-rn native:prepare",
    "rn:native:pods": "pnpm --filter @fortune/mobile-rn native:pods",
    "rn:native:build": "pnpm --filter @fortune/mobile-rn native:build",
    "rn:native:device:build": "pnpm --filter @fortune/mobile-rn native:device:build",
    "rn:native:device:install": "pnpm --filter @fortune/mobile-rn native:device:install",
    "rn:native:device:launch": "pnpm --filter @fortune/mobile-rn native:device:launch",
    "rn:native:device:run": "pnpm --filter @fortune/mobile-rn native:device:run",
    "rn:ios:xcode": "pnpm --filter @fortune/mobile-rn ios:xcode",
    "rn:ios:local": "pnpm --filter @fortune/mobile-rn ios:local"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@supabase/supabase-js": "^2.86.2",
    "openai": "^6.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.5"
  },
  "author": "Fortune Team",
  "license": "MIT",
  "overrides": {
    "expo-font": "14.0.11",
    "react-native-worklets": "0.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "llama.rn",
      "sharp",
      "esbuild",
      "@sentry/cli",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.1",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "packageManager": "pnpm@10.33.1"
}
