{
  "name": "fortune-monorepo",
  "version": "1.0.0",
  "description": "Ondo (온도) — AI fortune & companion chat app monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "source-inventory:generate": "python3 scripts/source_inventory.py generate",
    "source-inventory:check": "python3 scripts/source_inventory.py check",
    "repo:sync": "npm run source-inventory:generate",
    "pencil:version": "npx -y @pencil.dev/cli version",
    "pencil:login": "npx -y @pencil.dev/cli login",
    "pencil:status": "npx -y @pencil.dev/cli status",
    "pencil:interactive": "npx -y @pencil.dev/cli interactive",
    "lint": "echo \"No frontend lint configured in CI. Skipping.\"",
    "typecheck": "echo \"No static typecheck configured in CI. Skipping.\"",
    "build": "echo \"No frontend build configured in CI. Skipping.\"",
    "test": "playwright test",
    "test:smoke": "playwright test playwright/tests/smoke.spec.js --project=chromium",
    "test:smoke:ci": "CI=true playwright test playwright/tests/smoke.spec.js --project=chromium",
    "test:e2e": "playwright test playwright/tests/e2e/",
    "test:e2e:ci": "CI=true playwright test playwright/tests/e2e/ --project=chromium",
    "test:comprehensive": "playwright test playwright/tests/comprehensive-fortune.spec.js",
    "test:comprehensive:ci": "CI=true playwright test playwright/tests/comprehensive-fortune.spec.js --project=chromium",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:codegen": "playwright codegen",
    "rn:typecheck": "npm run typecheck --workspace @fortune/product-contracts --workspace @fortune/design-tokens --workspace @fortune/mobile-rn",
    "rn:test": "npm run test --workspace @fortune/product-contracts",
    "lighthouse": "lhci autorun",
    "serve:build": "npx serve build/web -l 3000 --single",
    "paper:guard": "node scripts/design/paper_sync_guard.js",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@supabase/supabase-js": "^2.86.2",
    "openai": "^6.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.5"
  },
  "author": "Fortune Team",
  "license": "MIT",
  "overrides": {
    "expo-font": "14.0.11"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.1",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
